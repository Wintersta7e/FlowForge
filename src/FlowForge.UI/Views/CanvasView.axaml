<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FlowForge.UI.ViewModels"
             xmlns:nodify="using:Nodify.Avalonia"
             xmlns:nodifyConn="using:Nodify.Avalonia.Connections"
             mc:Ignorable="d"
             d:DesignWidth="600" d:DesignHeight="400"
             x:Class="FlowForge.UI.Views.CanvasView"
             x:DataType="vm:EditorViewModel">

    <Grid>
        <nodify:NodifyEditor x:Name="Editor"
                             ItemsSource="{Binding Nodes}"
                             Connections="{Binding Connections}"
                             PendingConnection="{Binding PendingConnection}"
                             ItemsDragStartedCommand="{Binding ItemsDragStartedCommand}"
                             ItemsDragCompletedCommand="{Binding ItemsDragCompletedCommand}"
                             Background="{DynamicResource ForgeBg}"
                             GridCellSize="20"
                             DragDrop.AllowDrop="True">

            <nodify:NodifyEditor.Styles>
                <Style Selector="nodify|ItemContainer" x:DataType="vm:PipelineNodeViewModel">
                    <Setter Property="Location" Value="{Binding Location, Mode=TwoWay}" />
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Padding" Value="0" />
                </Style>
                <!-- Hide the selection highlight border from ItemContainer -->
                <Style Selector="nodify|ItemContainer:selected">
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Background" Value="Transparent" />
                </Style>
            </nodify:NodifyEditor.Styles>

            <nodify:NodifyEditor.ItemTemplate>
                <DataTemplate x:DataType="vm:PipelineNodeViewModel">
                    <Grid>
                        <!-- Input connectors (left edge) -->
                        <ItemsControl ItemsSource="{Binding Input}"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Center"
                                      Margin="-7,0,0,0"
                                      IsHitTestVisible="True"
                                      ZIndex="5">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:PipelineConnectorViewModel">
                                    <nodifyConn:Connector Anchor="{Binding Anchor, Mode=OneWayToSource}"
                                                          IsConnected="{Binding IsConnected}"
                                                          Width="12" Height="12"
                                                          Background="{DynamicResource ForgeSurface}"
                                                          BorderBrush="{Binding ConnectorBrush}"
                                                          BorderThickness="2"
                                                          CornerRadius="2"
                                                          RenderTransformOrigin="0.5,0.5"
                                                          Cursor="Hand">
                                        <nodifyConn:Connector.RenderTransform>
                                            <RotateTransform Angle="45" />
                                        </nodifyConn:Connector.RenderTransform>
                                    </nodifyConn:Connector>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Node body -->
                        <Border CornerRadius="16"
                                Background="{Binding NodeBackground}"
                                BorderBrush="{Binding NodeBorderBrush}"
                                BorderThickness="1"
                                Margin="6,0"
                                ClipToBounds="True"
                                MinWidth="160"
                                MaxWidth="240">
                            <StackPanel>
                                <!-- Header -->
                                <Border Padding="10,8"
                                        Background="{Binding HeaderBrush}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Width="26" Height="26" CornerRadius="8"
                                                Background="{Binding NodeBorderBrush}">
                                            <TextBlock Text="{Binding IconEmoji}"
                                                       FontFamily="Segoe UI Emoji"
                                                       FontSize="13"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding CategoryBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <!-- Subtle separator -->
                                <Border Height="1" Opacity="0.05" Background="White" />
                                <!-- Body: config preview -->
                                <Border Padding="10,6,10,8"
                                        IsVisible="{Binding ConfigPreview, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Text="{Binding ConfigPreview}"
                                               FontFamily="Cascadia Mono,Consolas,monospace"
                                               FontSize="11"
                                               Foreground="{DynamicResource ForgeTextMuted}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="200" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Output connectors (right edge) -->
                        <ItemsControl ItemsSource="{Binding Output}"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,-7,0"
                                      IsHitTestVisible="True"
                                      ZIndex="5">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:PipelineConnectorViewModel">
                                    <nodifyConn:Connector Anchor="{Binding Anchor, Mode=OneWayToSource}"
                                                          IsConnected="{Binding IsConnected}"
                                                          Width="12" Height="12"
                                                          Background="{DynamicResource ForgeSurface}"
                                                          BorderBrush="{Binding ConnectorBrush}"
                                                          BorderThickness="2"
                                                          CornerRadius="2"
                                                          RenderTransformOrigin="0.5,0.5"
                                                          Cursor="Hand">
                                        <nodifyConn:Connector.RenderTransform>
                                            <RotateTransform Angle="45" />
                                        </nodifyConn:Connector.RenderTransform>
                                    </nodifyConn:Connector>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </DataTemplate>
            </nodify:NodifyEditor.ItemTemplate>

            <nodify:NodifyEditor.ConnectionTemplate>
                <DataTemplate x:DataType="vm:PipelineConnectionViewModel">
                    <nodifyConn:Connection Source="{Binding Source.Anchor}"
                                           Target="{Binding Target.Anchor}"
                                           Stroke="{DynamicResource ForgeAccent}"
                                           StrokeThickness="2" />
                </DataTemplate>
            </nodify:NodifyEditor.ConnectionTemplate>

            <nodify:NodifyEditor.PendingConnectionTemplate>
                <DataTemplate x:DataType="vm:PipelinePendingConnectionViewModel">
                    <nodifyConn:PendingConnection IsVisible="{Binding IsVisible}"
                                                  StartedCommand="{Binding StartCommand}"
                                                  CompletedCommand="{Binding FinishCommand}"
                                                  EnablePreview="True"
                                                  EnableSnapping="True"
                                                  PreviewTarget="{Binding PreviewTarget, Mode=OneWayToSource}" />
                </DataTemplate>
            </nodify:NodifyEditor.PendingConnectionTemplate>

        </nodify:NodifyEditor>

        <!-- Empty state overlay -->
        <Border IsVisible="{Binding !HasNodes}"
                IsHitTestVisible="True"
                DragDrop.AllowDrop="True">
            <Border.Background>
                <SolidColorBrush Color="{DynamicResource ForgeBgColor}" Opacity="0.7" />
            </Border.Background>
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="20"
                        MaxWidth="400">

                <!-- Large gear icon with glow ring -->
                <Border Width="84" Height="84"
                        CornerRadius="24"
                        HorizontalAlignment="Center"
                        BorderThickness="2"
                        BorderBrush="{DynamicResource ForgeAccent}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Color="{DynamicResource ForgeSurfaceColor}" Offset="0" />
                            <GradientStop Color="{DynamicResource ForgeElevatedColor}" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <PathIcon Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.04 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                              Foreground="{DynamicResource ForgeAccent}"
                              Width="36" Height="36"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                </Border>

                <TextBlock Text="Forge your pipeline"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{DynamicResource ForgeAccent}"
                           HorizontalAlignment="Center" />

                <TextBlock Text="Drag nodes from the sidebar or start with a template"
                           FontSize="13"
                           Foreground="{DynamicResource ForgeTextSecondary}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />

                <UniformGrid Columns="2" HorizontalAlignment="Center"
                             Rows="2" MaxWidth="320">
                    <Button Classes="templateButton" Margin="4"
                            Tag="photo-import-by-date"
                            Click="OnTemplateButtonClick">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#x1F4F7;" FontFamily="Segoe UI Emoji" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text="Photo Import" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Classes="templateButton" Margin="4"
                            Tag="batch-sequential-rename"
                            Click="OnTemplateButtonClick">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#x270E;" FontFamily="Segoe UI Emoji" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text="Batch Rename" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Classes="templateButton" Margin="4"
                            Tag="image-web-export"
                            Click="OnTemplateButtonClick">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#x1F310;" FontFamily="Segoe UI Emoji" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text="Web Export" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Classes="templateButton" Margin="4"
                            Tag="bulk-image-compress"
                            Click="OnTemplateButtonClick">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#x1F4E6;" FontFamily="Segoe UI Emoji" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text="Compress" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </UniformGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
