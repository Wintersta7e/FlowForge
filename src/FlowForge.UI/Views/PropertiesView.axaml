<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FlowForge.UI.ViewModels"
             xmlns:views="using:FlowForge.UI.Views"
             mc:Ignorable="d"
             d:DesignWidth="290" d:DesignHeight="600"
             x:Class="FlowForge.UI.Views.PropertiesView"
             x:DataType="vm:PropertiesViewModel">

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Padding="14,14,14,10"
                BorderBrush="{DynamicResource ForgeBorder}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="8">
                <TextBlock Text="PROPERTIES"
                           FontSize="10"
                           FontWeight="Bold"
                           Foreground="{DynamicResource ForgeTextMuted}" />
                <Border IsVisible="{Binding HasSelection}"
                        Background="{Binding BadgeBackground}"
                        CornerRadius="8"
                        Padding="10,6">
                    <TextBlock Text="{Binding SelectedNodeTitle}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{Binding BadgeForeground}" />
                </Border>
            </StackPanel>
        </Border>

        <StackPanel IsVisible="{Binding !HasSelection}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="4"
                    Margin="16">
            <TextBlock Text="Select a node to edit its settings"
                       FontSize="13"
                       Foreground="{DynamicResource ForgeTextMuted}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center" />
        </StackPanel>

        <ScrollViewer IsVisible="{Binding HasSelection}"
                      Padding="10">
            <ItemsControl ItemsSource="{Binding Fields}">
                <ItemsControl.ItemTemplate>
                    <views:ConfigFieldTemplateSelector />
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
