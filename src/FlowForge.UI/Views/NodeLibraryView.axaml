<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FlowForge.UI.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="250" d:DesignHeight="600"
             x:Class="FlowForge.UI.Views.NodeLibraryView"
             x:DataType="vm:NodeLibraryViewModel">

    <UserControl.DataTemplates>
        <DataTemplate x:DataType="vm:NodeLibraryItemViewModel">
            <Border Padding="8,6"
                    CornerRadius="8"
                    Cursor="Hand"
                    Background="Transparent"
                    BorderThickness="2,0,0,0"
                    BorderBrush="Transparent"
                    DoubleTapped="OnLibraryItemDoubleTapped"
                    PointerPressed="OnLibraryItemPointerPressed"
                    PointerMoved="OnLibraryItemPointerMoved"
                    PointerReleased="OnLibraryItemPointerReleased">
                <Border.Styles>
                    <Style Selector="Border:pointerover">
                        <Setter Property="Background" Value="{DynamicResource ForgeElevated}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource ForgeAccent}" />
                    </Style>
                </Border.Styles>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border Width="28" Height="28" CornerRadius="8"
                            Background="{DynamicResource ForgeElevated}">
                        <TextBlock Text="{Binding Icon}"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="{Binding DisplayName}"
                               Foreground="{DynamicResource ForgeText}"
                               FontSize="12.5"
                               FontWeight="Medium"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.DataTemplates>

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="14,14,14,4">
            <TextBlock Text="NODE LIBRARY"
                       FontSize="10"
                       FontWeight="Bold"
                       Foreground="{DynamicResource ForgeTextMuted}"
                       Margin="0,0,0,2" />
            <TextBlock Text="Drag or double-click to add"
                       FontSize="11"
                       Foreground="{DynamicResource ForgeTextSecondary}"
                       Margin="0,2,0,0" />
        </StackPanel>

        <TextBox DockPanel.Dock="Top"
                 Text="{Binding SearchText}"
                 Watermark="Search nodes..."
                 Margin="10,10,10,4" />

        <TreeView ItemsSource="{Binding Groups}"
                  Margin="6,4,6,4"
                  Background="Transparent">
            <TreeView.ItemTemplate>
                <TreeDataTemplate x:DataType="vm:NodeLibraryGroupViewModel"
                                  ItemsSource="{Binding Items}">
                    <TextBlock Text="{Binding Category}"
                               FontWeight="Bold"
                               FontSize="10"
                               Foreground="{DynamicResource ForgeTextMuted}"
                               Margin="0,10,0,4" />
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </DockPanel>
</UserControl>
