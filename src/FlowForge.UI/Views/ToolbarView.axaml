<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FlowForge.UI.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="800" d:DesignHeight="40"
             x:Class="FlowForge.UI.Views.ToolbarView"
             x:DataType="vm:MainWindowViewModel">

    <DockPanel>
        <!-- Molten gradient accent line at bottom -->
        <Border DockPanel.Dock="Bottom" Height="2" Opacity="0.5">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                    <GradientStop Color="Transparent" Offset="0" />
                    <GradientStop Color="#d4612c" Offset="0.2" />
                    <GradientStop Color="#f5a623" Offset="0.5" />
                    <GradientStop Color="#f5c842" Offset="0.8" />
                    <GradientStop Color="Transparent" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Main toolbar content -->
        <Border Background="{DynamicResource ForgePanel}"
                BorderBrush="{DynamicResource ForgeBorder}"
                BorderThickness="0,0,0,1"
                Padding="10,6">
            <DockPanel>
                <!-- Right side: shortcuts button -->
                <Button DockPanel.Dock="Right"
                        Classes="toolbarIcon"
                        ToolTip.Tip="Keyboard Shortcuts (F1)"
                        Click="OnShowShortcutsClick"
                        Margin="4,0">
                    <TextBlock Text="?"
                               FontWeight="Bold"
                               FontSize="14"
                               Foreground="{DynamicResource ForgeText}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Button>

                <!-- Right side: title -->
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding Title}"
                           Foreground="{DynamicResource ForgeTextMuted}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Margin="8,0" />

                <!-- Center brand text -->
                <TextBlock DockPanel.Dock="Right"
                           Text="FLOWFORGE"
                           FontWeight="ExtraBold"
                           FontSize="14"
                           Foreground="{DynamicResource ForgeAccent}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="12,0" />

                <!-- Left side: all buttons -->
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <!-- File buttons -->
                    <Button Classes="toolbarIcon"
                            Command="{Binding NewCommand}"
                            ToolTip.Tip="New Pipeline (Ctrl+N)">
                        <PathIcon Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                                  Foreground="{DynamicResource ForgeText}"
                                  Width="16" Height="16" />
                    </Button>
                    <Button Classes="toolbarIcon"
                            Command="{Binding OpenCommand}"
                            ToolTip.Tip="Open Pipeline (Ctrl+O)">
                        <PathIcon Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"
                                  Foreground="{DynamicResource ForgeText}"
                                  Width="16" Height="16" />
                    </Button>
                    <Button x:Name="RecentButton"
                            Classes="toolbarIcon"
                            ToolTip.Tip="Recent Pipelines">
                        <Button.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedLeft" />
                        </Button.Flyout>
                        <PathIcon Data="M12,6V9L16,5L12,1V4A8,8 0 0,0 4,12C4,13.57 4.46,15.03 5.24,16.26L6.7,14.8C6.25,13.97 6,13 6,12A6,6 0 0,1 12,6M18.76,7.74L17.3,9.2C17.74,10.04 18,11 18,12A6,6 0 0,1 12,18V15L8,19L12,23V20A8,8 0 0,0 20,12C20,10.43 19.54,8.97 18.76,7.74Z"
                                  Foreground="{DynamicResource ForgeText}"
                                  Width="16" Height="16" />
                    </Button>
                    <Button Classes="toolbarIcon"
                            Command="{Binding SaveCommand}"
                            ToolTip.Tip="Save (Ctrl+S)">
                        <PathIcon Data="M15,9H5V5H15M12,19A3,3 0 0,1 9,16A3,3 0 0,1 12,13A3,3 0 0,1 15,16A3,3 0 0,1 12,19M17,3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V7L17,3Z"
                                  Foreground="{DynamicResource ForgeText}"
                                  Width="16" Height="16" />
                    </Button>
                    <Button Classes="toolbarIcon"
                            Command="{Binding SaveAsCommand}"
                            ToolTip.Tip="Save As (Ctrl+Shift+S)">
                        <PathIcon Data="M17,3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V7L17,3M15,9H5V5H15M12,19A3,3 0 0,1 9,16A3,3 0 0,1 12,13A3,3 0 0,1 15,16A3,3 0 0,1 12,19Z"
                                  Foreground="{DynamicResource ForgeTextSecondary}"
                                  Width="16" Height="16" />
                    </Button>

                    <!-- Separator -->
                    <Border Width="1"
                            Height="24"
                            Background="{DynamicResource ForgeBorder}"
                            VerticalAlignment="Center"
                            Margin="4,0" />

                    <!-- Undo/Redo -->
                    <Button Classes="toolbarIcon"
                            Command="{Binding UndoCommand}"
                            ToolTip.Tip="Undo (Ctrl+Z)">
                        <PathIcon Data="M12.5,8C9.85,8 7.45,9.16 5.86,11L3,8V16H11L7.9,12.9C9.09,11.84 10.73,11.19 12.5,11.19C15.49,11.19 18.04,13.18 18.86,16L21.73,15.14C20.6,11.14 16.86,8 12.5,8Z"
                                  Foreground="{DynamicResource ForgeText}"
                                  Width="16" Height="16" />
                    </Button>
                    <Button Classes="toolbarIcon"
                            Command="{Binding RedoCommand}"
                            ToolTip.Tip="Redo (Ctrl+Y)">
                        <PathIcon Data="M18.14,11C16.55,9.16 14.15,8 11.5,8C7.14,8 3.4,11.14 2.27,15.14L5.14,16C5.96,13.18 8.5,11.19 11.5,11.19C13.27,11.19 14.91,11.84 16.1,12.9L13,16H21V8L18.14,11Z"
                                  Foreground="{DynamicResource ForgeText}"
                                  Width="16" Height="16" />
                    </Button>

                    <!-- Separator -->
                    <Border Width="1"
                            Height="24"
                            Background="{DynamicResource ForgeBorder}"
                            VerticalAlignment="Center"
                            Margin="4,0" />

                    <!-- Fit to screen -->
                    <Button Classes="toolbarIcon"
                            ToolTip.Tip="Fit to Screen (Ctrl+0)"
                            Click="OnFitToScreenClick">
                        <PathIcon Data="M3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3H5A2,2 0 0,0 3,5M5,5H19V19H5V5M7,7V9H9V7H7M15,7V9H17V7H15M7,15V17H9V15H7M15,15V17H17V15H15Z"
                                  Foreground="{DynamicResource ForgeText}"
                                  Width="16" Height="16" />
                    </Button>

                    <!-- Separator -->
                    <Border Width="1"
                            Height="24"
                            Background="{DynamicResource ForgeBorder}"
                            VerticalAlignment="Center"
                            Margin="4,0" />

                    <!-- Run/Preview/Stop -->
                    <Button Command="{Binding RunCommand}"
                            Classes="accent"
                            ToolTip.Tip="Run Pipeline"
                            Padding="12,4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="M8,5.14V19.14L19,12.14L8,5.14Z"
                                      Foreground="#08070a"
                                      Width="12" Height="12" />
                            <TextBlock Text="Run" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding DryRunCommand}"
                            Classes="preview"
                            ToolTip.Tip="Preview — simulate run without changing any files"
                            Padding="12,4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z"
                                      Foreground="{DynamicResource ForgeAccent}"
                                      Width="12" Height="12" />
                            <TextBlock Text="Preview" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding CancelCommand}"
                            IsVisible="{Binding ExecutionLog.IsRunning}"
                            ToolTip.Tip="Stop Execution"
                            Padding="12,4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="M18,18H6V6H18V18Z"
                                      Foreground="{DynamicResource ForgeError}"
                                      Width="12" Height="12" />
                            <TextBlock Text="Stop" Foreground="{DynamicResource ForgeError}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>
    </DockPanel>
</UserControl>
