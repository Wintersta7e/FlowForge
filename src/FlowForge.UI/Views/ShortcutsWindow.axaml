<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FlowForge.UI.Views.ShortcutsWindow"
        Title="Keyboard Shortcuts"
        Width="420" Height="440"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ForgePanel}">

    <StackPanel Margin="24" Spacing="16">
        <TextBlock Text="Keyboard Shortcuts"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="{DynamicResource ForgeAccent}" />

        <Border Background="{DynamicResource ForgeDeep}"
                CornerRadius="12"
                Padding="16,12"
                BorderBrush="{DynamicResource ForgeBorder}"
                BorderThickness="1">
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                <Grid.Styles>
                    <Style Selector="TextBlock.key">
                        <Setter Property="FontFamily" Value="Cascadia Mono,Consolas,monospace" />
                        <Setter Property="FontSize" Value="12" />
                        <Setter Property="Foreground" Value="{DynamicResource ForgeAccent}" />
                        <Setter Property="Background" Value="{DynamicResource ForgeElevated}" />
                        <Setter Property="Padding" Value="6,2" />
                        <Setter Property="Margin" Value="0,4,16,4" />
                    </Style>
                    <Style Selector="TextBlock.desc">
                        <Setter Property="FontSize" Value="12.5" />
                        <Setter Property="Foreground" Value="{DynamicResource ForgeText}" />
                        <Setter Property="Margin" Value="0,4" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                </Grid.Styles>

                <TextBlock Grid.Row="0" Grid.Column="0" Classes="key" Text="Ctrl+N" />
                <TextBlock Grid.Row="0" Grid.Column="1" Classes="desc" Text="New pipeline" />

                <TextBlock Grid.Row="1" Grid.Column="0" Classes="key" Text="Ctrl+O" />
                <TextBlock Grid.Row="1" Grid.Column="1" Classes="desc" Text="Open pipeline" />

                <TextBlock Grid.Row="2" Grid.Column="0" Classes="key" Text="Ctrl+S" />
                <TextBlock Grid.Row="2" Grid.Column="1" Classes="desc" Text="Save" />

                <TextBlock Grid.Row="3" Grid.Column="0" Classes="key" Text="Ctrl+Shift+S" />
                <TextBlock Grid.Row="3" Grid.Column="1" Classes="desc" Text="Save as" />

                <TextBlock Grid.Row="4" Grid.Column="0" Classes="key" Text="Delete" />
                <TextBlock Grid.Row="4" Grid.Column="1" Classes="desc" Text="Remove selected nodes" />

                <TextBlock Grid.Row="5" Grid.Column="0" Classes="key" Text="Ctrl+0" />
                <TextBlock Grid.Row="5" Grid.Column="1" Classes="desc" Text="Zoom to fit all nodes" />

                <TextBlock Grid.Row="6" Grid.Column="0" Classes="key" Text="Space+Drag" />
                <TextBlock Grid.Row="6" Grid.Column="1" Classes="desc" Text="Pan canvas" />

                <TextBlock Grid.Row="7" Grid.Column="0" Classes="key" Text="Ctrl+Scroll" />
                <TextBlock Grid.Row="7" Grid.Column="1" Classes="desc" Text="Zoom in/out" />

                <TextBlock Grid.Row="8" Grid.Column="0" Classes="key" Text="Ctrl+Z" />
                <TextBlock Grid.Row="8" Grid.Column="1" Classes="desc" Text="Undo" />

                <TextBlock Grid.Row="9" Grid.Column="0" Classes="key" Text="Ctrl+Y" />
                <TextBlock Grid.Row="9" Grid.Column="1" Classes="desc" Text="Redo" />

                <TextBlock Grid.Row="10" Grid.Column="0" Classes="key" Text="F1" />
                <TextBlock Grid.Row="10" Grid.Column="1" Classes="desc" Text="Show this help" />
            </Grid>
        </Border>

        <Button Content="Close"
                Classes="accent"
                HorizontalAlignment="Right"
                Padding="16,6"
                Click="OnCloseClick" />
    </StackPanel>
</Window>
